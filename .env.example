# Sao chép thành .env (file .env đã được gitignore)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Đăng nhập app dùng Firebase Authentication (email/password). Realtime Database (VITE_FIREBASE_DATABASE_URL)
# chỉ để đọc/ghi dữ liệu — không thay thế Authentication; lỗi auth/configuration-not-found vẫn cần bật Auth + Identity Toolkit API.
# - Firebase Console → Authentication → Get started (lần đầu) → Sign-in method → Email/Password → Enable.
# - Google Cloud Console (cùng project) → APIs & Services → bật API «Identity Toolkit API».
# - Đối chiếu VITE_FIREBASE_* với Project settings → Your apps (Web). Sửa .env xong chạy lại dev server.

# Realtime Database (URL đầy đủ từ Firebase Console)
VITE_FIREBASE_DATABASE_URL=

# Google Analytics (tuỳ chọn — Web app)
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore: BẮT BUỘC nếu CRM dùng database «warmlist» (Functions OMICall/KPI ghi vào đây — không dùng (default))
VITE_FIREBASE_FIRESTORE_DATABASE_ID=warmlist

# Email super admin — khi đăng nhập khớp, Firestore `users/{uid}` được gán role `admin`.
# Tạo user Authentication (email + mật khẩu) trong Firebase Console — không lưu mật khẩu trong Git / .env.
# Domain: caodangvietmy.edu.vn (đừng nhầm thành caodangviemy).
# VITE_SUPER_ADMIN_EMAIL=quan.duong@caodangvietmy.edu.vn
#
# --- Cổng kế toán (/ke-toan) ---
# Email kế toán mặc định — khi đăng nhập khớp, Firestore `users/{uid}` được gán role `accountant`.
# VITE_DEFAULT_ACCOUNTANT_EMAIL=quan.duong@caodangvietmy.edu.vn
#
# Tạo tài khoản kế toán (một lần, không commit mật khẩu):
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json SEED_ACCOUNTANT_PASSWORD='...' npm run seed:accountant
# Tuỳ chọn: SEED_ACCOUNTANT_EMAIL=quan.duong@caodangvietmy.edu.vn
#
# Sau lần đăng nhập đầu của admin: app tự ghi seed Firestore một lần (masterData, scoringProfiles mẫu, playbook mẫu, meta/firestoreSeed)
# nếu Rules cho phép. Không thay thế việc bật Authentication + tạo user trong Console.
#
# --- Tạo super admin tự động trên máy (không hardcode mật khẩu trong Git) ---
# 1) Tải JSON service account: Firebase Console → Project settings → Service accounts → Generate new private key
#    → lưu ví dụ: secrets/serviceAccount.json (thư mục secrets đã gitignore)
# 2) Chạy một lần (thay mật khẩu thật, không commit lệnh này vào repo công khai):
#    GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json SEED_ADMIN_PASSWORD='...' npm run seed:super-admin
#    Tuỳ chọn: SEED_ADMIN_EMAIL=quan.duong@caodangvietmy.edu.vn (mặc định đúng email này)

# --- OpenAI (ChatGPT) từ trình duyệt và CORS ---
# Trang web không gọi trực tiếp api.openai.com; app dùng đường dẫn cùng domain `…/openai-proxy/v1/chat/completions` (kèm VITE_BASE nếu deploy dưới subpath).
# - «npm run dev» và «npm run preview»: Vite proxy chuyển tiếp tới OpenAI (không cần .env cho URL).
# - Hosting tĩnh (GitHub Pages, v.v.): cần reverse proxy cùng path hoặc build với URL proxy đầy đủ, ví dụ Cloud Function:
#   VITE_OPENAI_PROXY_URL=https://your-project.cloudfunctions.net/openaiChat
# Không đặt URL này (hay VITE_AI_API_URL) trỏ tới https://api.openai.com — trình duyệt vẫn bị CORS; app sẽ bỏ qua và dùng /openai-proxy.
# Hoặc dùng biến cũ (một URL POST tương thích OpenAI Chat Completions):
# VITE_AI_API_URL=https://your-proxy.example/v1/chat/completions
# VITE_AI_API_KEY=sk-...   # chỉ khi không lưu khóa trong Cài đặt → LLM (localStorage); ưu tiên localStorage nếu đã lưu
# VITE_AI_PROVIDER=OpenAI   # hoặc Gemini — mặc định OpenAI khi chỉ có VITE_AI_API_KEY
# VITE_AI_MODEL=gpt-4o-mini

# n8n — tài chính & giấy mời (mặc định giống hệ Apps Script cũ nếu bỏ trống)
# VITE_N8N_WEBHOOK=https://apchn-host.lapage.vn/webhook/giaymoits
# VITE_N8N_WEBHOOK_CTSV=https://apchn-host.lapage.vn/webhook/testctsv
# VITE_N8N_WEBHOOK_DAILY=https://apchn-host.lapage.vn/webhook/baocao-ngay
# VITE_N8N_WEBHOOK_MONTHLY=https://apchn-host.lapage.vn/webhook/baocao-thang
# Chứng từ thu (ưu tiên): Apps Script -> Google Drive
# VITE_RECEIPT_DRIVE_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
# VITE_RECEIPT_DRIVE_WEBHOOK_TOKEN=your-shared-token
# Fallback nếu không cấu hình webhook Drive: Firebase Storage (receipts/{HọTên_MãSV}/...)
#
# --- Vercel (Production) — biến môi trường bắt buộc ---
# Firebase (6): VITE_FIREBASE_API_KEY, VITE_FIREBASE_AUTH_DOMAIN, VITE_FIREBASE_PROJECT_ID,
#   VITE_FIREBASE_STORAGE_BUCKET, VITE_FIREBASE_MESSAGING_SENDER_ID, VITE_FIREBASE_APP_ID
# Tuỳ chọn: VITE_FIREBASE_FIRESTORE_DATABASE_ID (nếu không dùng database default)
# Cổng kế toán: VITE_DEFAULT_ACCOUNTANT_EMAIL=quan.duong@caodangvietmy.edu.vn
# n8n (workflow báo cáo + duyệt thu → Google Chat):
#   VITE_N8N_WEBHOOK_CTSV=https://apchn-host.lapage.vn/webhook/.../testctsv   ← TVV báo phí + kế toán duyệt
#   VITE_N8N_WEBHOOK_DAILY=https://apchn-host.lapage.vn/webhook/baocao-ngay
#   VITE_N8N_WEBHOOK_MONTHLY=https://apchn-host.lapage.vn/webhook/baocao-thang
#   VITE_N8N_WEBHOOK=https://apchn-host.lapage.vn/webhook/giaymoits          ← giấy mời TS
# Trên server n8n (apchn-host.lapage.vn): các workflow phải ở trạng thái Active.

# OMICall — gọi từ web (Web SDK). Cấu hình chính lưu Firestore: scoringAux/omicallIntegration (Cài đặt → Gọi điện).
# VITE_OMICALL_SDK_VERSION=3.0.41
# VITE_OMICALL_SIP_REALM=demo01
# VITE_OMICALL_SIP_USER=100
# VITE_OMICALL_SIP_PASSWORD=
# VITE_OMICALL_API_BASE_URL=   # REST sync — ưu tiên nhập trong Cài đặt → Gọi điện
# VITE_OMICALL_API_KEY=        # REST sync — ưu tiên nhập trong Cài đặt → Gọi điện; không commit giá trị thật
# VITE_OMICALL_WEBHOOK_SECRET= # Webhook sync — ưu tiên nhập trong Cài đặt → Gọi điện

# OMICall server sync — ưu tiên Firebase Functions Secret; nếu chưa có, Functions đọc các ô sync trong Cài đặt → Gọi điện.
# firebase functions:secrets:set OMICALL_API_KEY
# firebase functions:secrets:set OMICALL_API_BASE_URL
# firebase functions:secrets:set OMICALL_WEBHOOK_SECRET
# Functions mặc định ghi Firestore database `warmlist`; nếu đổi database, đặt env FIRESTORE_DATABASE_ID khi deploy.
# Webhook URL sau deploy: https://<region>-<project>.cloudfunctions.net/omicallCallWebhook?secret=<secret>

# Dev — giả lập vai trò RBAC (chỉ khi không khởi tạo được Firebase Auth — thiếu biến môi trường)
# VITE_DEV_IMPERSONATE_ROLE=admin
# VITE_DEV_IMPERSONATE_UID=local-dev-user

# --- KHÔNG dùng trong Vite / trình duyệt ---
# Service Account JSON chỉ dùng cho firebase-admin (Node, Cloud Functions).
# Không import file JSON này vào React. Giữ ngoài repo hoặc dùng secret manager.
